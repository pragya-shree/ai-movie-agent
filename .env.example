# Copy this file to .env for local development and fill in your real key.
# Never commit the real .env file.
#
# Get a TMDB API key at: https://www.themoviedb.org/settings/api

TMDB_API_KEY=your_tmdb_api_key_here

# Qwen API key — NOT YET USED. The AI-agent architecture (src/agent/)
# currently runs on a rule-based stub (StubLLMClient) that never reads
# this. It's here so the config surface is ready ahead of integration.
# Get a key at: https://www.alibabacloud.com/help/en/model-studio/
QWEN_API_KEY=your_qwen_api_key_here
