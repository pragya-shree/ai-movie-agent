# Copy this file to .env for local development and fill in your real key.
# Never commit the real .env file.
#
# Get a TMDB API key at: https://www.themoviedb.org/settings/api

TMDB_API_KEY=your_tmdb_api_key_here

# Gemini API key — used by gemini_client.py for the chat interface's
# conversational replies (both general chat and AI-narrated
# recommendations). Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
